#setting A to zero for each amino acid
A = np.zeros(N, dtype=int)

for i in range(N):
    if i == 0:
        A[i] = Gamma[i+1]
    elif i == N-1:
        A[i] = Gamma[i-1]
    else:
        A[i] = Gamma[i-1] + Gamma[i+1]

#checking if the ith amino acid is H
def M(x, y, coordinates):
    for i in range(N):
        if coordinates[i] == (x, y) and Gamma[i] == H:
            return 1
    return 0

#checking if the four amino acids around the amino acid is 0
def Mhat(i, coordinates):
    x, y = coordinates[i]
    return (M(x-1, y, coordinates) +M(x+1, y, coordinates) +M(x, y-1, coordinates) +M(x, y+1, coordinates))


#checking the self-avoiding walk, are all coordiantes unique?
def valid_fold(coordinates):
    return len(set(coordinates)) == len(coordinates)


def propose_move(d):
    d_new = d.copy()

    i = np.random.randint(len(d))

    current = d_new[i]

    # choose a different direction
    choices = [0, 1, 2, 3]
    choices.remove(current)

    d_new[i] = np.random.choice(choices)

    return d_new

coordinates = laydowncoordinates(d)

def energy(coordinates):
    E = 0
    for i in range(N):
        E += Gamma[i] * (A[i] - Mhat(i, coordinates))
    return E*0.5


