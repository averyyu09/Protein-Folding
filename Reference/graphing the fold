num_sweeps = 10000
beta = 0.5
beta_final = 1000
alpha = (beta_final / beta)**(1/(num_sweeps-1))

energies = []

for sweep in range(num_sweeps):

    while True:
        d_new = propose_move(d)
        coords_new = laydowncoordinates(d_new)

        if valid_fold(coords_new):
            break

    E_new = energy(coords_new)

    deltaE = E_new - E

    if deltaE <= 0:
        d = d_new
        coordinates = coords_new
        E = E_new

    elif np.random.rand() < np.exp(-beta * deltaE):
        d = d_new
        coordinates = coords_new
        E = E_new

    energies.append(E)
    if E < best_E:
        best_E = E
        best_coordinates = coordinates.copy()
        best_d = d.copy()

    best_energies.append(best_E)

    beta *= alpha

