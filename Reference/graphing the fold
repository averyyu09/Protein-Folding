#how each amino acid gets moved
def laydowncoordinates(d):
    coordinates = [(0, 0)]

    for move in d:
        #get the last bead
        x, y = coordinates[-1]

        if move == 0:
            coordinates.append((x-1, y))
        elif move == 1:
            coordinates.append((x+1, y))
        elif move == 2:
            coordinates.append((x, y+1))
        elif move == 3:
            coordinates.append((x, y-1))

    return coordinates
#turn the coordinates according to the changes--- first fold
coordinates = laydowncoordinates(d)


