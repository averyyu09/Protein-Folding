import numpy as np
import matplotlib.pyplot as plt

from Functions2 import (energywithpenalties, plot_results, propose_move2)

H = -1
P = 0

Gamma = [P, P, H, P, H, P, P, P, P, H, P, H, H, P, H, P]
N = len(Gamma)
coordinates = np.random.randint(0, N, size=(N, 2))
#print(coordinates)

E_hp = 0
E_bond = 0
E_overlap = 0
E = 0
N = len(Gamma)

E = energywithpenalties(Gamma, coordinates)
best_energy = E
best_coordinates = coordinates.copy()

energies = [E]
best_energies = [best_energy]

#edit these
num_sweeps = 100000
num_steps = 30
beta_steps = np.linspace(0.1, 10, num_steps)

step_size = int(np.ceil(num_sweeps / num_steps))
beta = np.repeat(beta_steps, step_size)
beta = beta[:num_sweeps]

for i in range(num_sweeps):

    new_coordinates = propose_move2(coordinates,N)

    E_new = energywithpenalties(Gamma,new_coordinates)

    deltaE = E_new-E

    if deltaE <= 0 or np.random.rand() < np.exp(-beta[i]*deltaE):

        coordinates = new_coordinates
        E = E_new

        if E < best_energy:
            best_energy = E
            best_coordinates = coordinates.copy()
    energies.append(E)
    best_energies.append(best_energy)




plot_results(energies, best_energies, coordinates, best_coordinates, Gamma, H, best_energy,)
print("Best energy:", best_energy)
print(best_coordinates)

burn_in = int(0.05 * len(energies))

plt.figure(figsize=(8, 5))
plt.plot(range(burn_in, len(energies)), energies[burn_in:])
plt.xlabel("Iteration")
plt.ylabel("Energy")
plt.title("Simulated Annealing (After Burn-in)")
plt.grid(True)
plt.show()





